# ── Twelve Data ────────────────────────────────────────────────────────────────
# Powers live ticker lookup for symbols outside the curated dataset.
# Free key at https://twelvedata.com — optional, manual classification works without it.
TWELVE_DATA_API_KEY=

# ── Resend ─────────────────────────────────────────────────────────────────────
# Powers the feedback form email delivery.
# Free key at https://resend.com — required for feedback emails to send.
RESEND_API_KEY=

# ── Feedback destination ───────────────────────────────────────────────────────
# The email address where user feedback form submissions get delivered.
FEEDBACK_EMAIL=
